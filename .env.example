# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=dein_telegram_bot_token_hier

# Erlaubte Telegram User-IDs (kommagetrennt, leer = alle erlaubt)
TELEGRAM_ALLOWED_USERS=123456789

# Ollama Einstellungen
OLLAMA_URL=http://ollama:11434
MAIN_MODEL=llama3.2:3b
WORKER_MODEL=llama3.2:1b

# Nachtzeit für niedrig-priorisierte Tasks (0-23)
NIGHT_START_HOUR=2
NIGHT_END_HOUR=6

# Datenpfad
DATA_DIR=/app/data
